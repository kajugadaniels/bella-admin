# ─────────────────────────────────────────────────────────────────────────────
# Backend API
# NOTE: Do NOT include a trailing slash or the /api suffix.
# Our frontend client already prefixes paths with /api/… (see src/api.js).
# Example request becomes: http://127.0.0.1:8000 + /api/auth/login/
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# ─────────────────────────────────────────────────────────────────────────────
# Micro-frontends (origins)
# Keep these as full origins (scheme + host + port, no trailing slash)
# ─────────────────────────────────────────────────────────────────────────────
VITE_SERVICE_AUTH_ORIGIN=http://localhost:5173
VITE_SERVICE_APP_ORIGIN=http://localhost:5174
VITE_SERVICE_MARKETING_ORIGIN=http://localhost:5175

# ─────────────────────────────────────────────────────────────────────────────
# Global navigation targets
# Use these for programmatic redirects (e.g., after login/logout) and hard links
# (e.g., footer: About / Terms / Privacy). Keeping them in env avoids hardcoding.
# ─────────────────────────────────────────────────────────────────────────────
VITE_AFTER_LOGIN_URL=${VITE_SERVICE_APP_ORIGIN}/
VITE_AFTER_LOGOUT_URL=${VITE_SERVICE_AUTH_ORIGIN}/

VITE_ABOUT_URL=${VITE_SERVICE_MARKETING_ORIGIN}/about
VITE_TERMS_URL=${VITE_SERVICE_MARKETING_ORIGIN}/terms
VITE_PRIVACY_URL=${VITE_SERVICE_MARKETING_ORIGIN}/privacy

# ─────────────────────────────────────────────────────────────────────────────
# Auth transport mode
# localstorage = tokens stored per-origin (simple, but not shared across apps)
# cookie       = backend sets HttpOnly cookies; frontends use fetch credentials,
#                enabling SSO across all frontends that talk to the same API.
# For true multi-app SSO, prefer "cookie" and configure CORS/Set-Cookie server-side.
# ─────────────────────────────────────────────────────────────────────────────
VITE_AUTH_TOKENS_MODE=localstorage

# ─────────────────────────────────────────────────────────────────────────────
# CORS allowlist (optional helper for your build/deploy scripts)
# ─────────────────────────────────────────────────────────────────────────────
VITE_ALLOWED_ORIGINS=${VITE_SERVICE_AUTH_ORIGIN},${VITE_SERVICE_APP_ORIGIN},${VITE_SERVICE_MARKETING_ORIGIN}

# ─────────────────────────────────────────────────────────────────────────────
# App branding (optional)
# ─────────────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Bella
